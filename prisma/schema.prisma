generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7+: url/directUrl artık burada değil, prisma.config.ts içinde tanımlı.
datasource db {
  provider = "postgresql"
}

// ─── Enum'lar ────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TEAM
  CLIENT
}

enum ContentStatus {
  PLANNED
  SHOOTING
  EDITING
  INTERNAL_REVIEW
  CLIENT_REVIEW
  APPROVED
  LIVE
  PUBLISHED
  // İptal edildi — /icerikler sayfasında ayrı kategori. APPROVED'den sonra
  // proje iptal olduysa (müşteri vazgeçti, çekim iptal vb.) bu duruma alınır.
  CANCELLED
}

// Projenin amacı — birden fazla seçilebilir (örn. hem TANITIM hem KAMPANYA).
// Süreç Yönetimi sayfasındaki "Amaç" çoklu seçim kutusunu besler.
enum Purpose {
  BILGI       // Bilgilendirme
  EGLENCE     // Eğlence
  TANITIM     // Tanıtım
  KAMPANYA    // Kampanya
  POST        // Düz post / genel
}

// Müşteri dosya kategorisi — sözleşme/fatura/diğer.
// File modeli proje-bazlı medya için kullanılıyor; bu ise client-level evrak.
enum ClientDocumentKind {
  CONTRACT     // Sözleşme
  INVOICE_DOC  // Fatura belgesi (kesilmiş PDF)
  OTHER        // Diğer (vekalet, kimlik, vb.)
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  LINKEDIN
  TWITTER
  YOUTUBE
}

enum PostType {
  IMAGE
  VIDEO
  REEL
  STORY
  CAROUSEL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

enum NotificationType {
  TASK_ASSIGNED
  FILE_UPLOADED
  INTERNAL_APPROVED
  CLIENT_APPROVED
  CLIENT_REVISION
  POST_FAILED
  TOKEN_EXPIRING
  REMINDER
  INVOICE_SENT
  INVOICE_PAID
  INVOICE_OVERDUE
  INVOICE_DUE_SOON
  // Reklam çıkıldı işaretlenmedi — yayından N saat sonra adRequired=true
  // adPosted=false olan ScheduledPost için tetiklenir.
  AD_NOT_POSTED
  // Faturası kesilmemiş subscription — nextInvoiceDate'e 7 gün kaldı,
  // hâlâ otomatik fatura üretilmemiş (cron erken uyarı).
  INVOICE_NOT_GENERATED
}

enum Currency {
  TRY
  USD
  EUR
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum SubscriptionInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SentimentCategory {
  POSITIVE
  NEUTRAL
  CONCERNED
  DISAPPOINTED
  URGENT
}

// ─── Kullanıcılar ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(TEAM)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts          Account[]
  sessions          Session[]
  teamAssignments   TeamAssignment[]
  tasks             Task[]             @relation("AssignedTo")
  notifications     Notification[]
  approvals         Approval[]
  activityLogs      ActivityLog[]
  notificationPrefs NotificationPref[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Müşteriler ───────────────────────────────────────────────────────────────

model Client {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  logo           String?
  industry       String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  brandColors    Json?
  brandVoice     String?
  bannedWords    String[]
  emojiPolicy    Boolean   @default(true)
  revisionQuota  Int       @default(3)
  portalToken    String?   @unique
  healthScore    Int       @default(100)
  // Faturalama bilgileri — Türk mevzuatı için gerekli
  taxId          String?   // VKN (10 haneli) veya TCKN (11 haneli)
  taxOffice      String?   // Vergi dairesi (ör. "Kadıköy")
  billingAddress String?   // Fatura adresi
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  socialAccounts  SocialAccount[]
  projects        Project[]
  teamAssignments TeamAssignment[]
  notifications   Notification[]
  invoices        Invoice[]
  subscriptions   Subscription[]
  documents       ClientDocument[]

  @@index([slug])
}

// Müşteri-bazlı evrak (sözleşme, fatura PDF, vb.). Project.files medya
// için, bu ise yönetimsel evrak. Ödemeler kart sayfasından upload edilir,
// listelenir, indirilir.
model ClientDocument {
  id         String             @id @default(cuid())
  clientId   String
  kind       ClientDocumentKind
  name       String             // dosya adı (kullanıcının yüklediği)
  label      String?            // opsiyonel etiket: "2026 Mart Sözleşme"
  mimeType   String
  sizeBytes  Int
  storageKey String             @unique
  publicUrl  String
  // İlişkili fatura (kind=INVOICE_DOC ise) — bağlamak istenirse dolu.
  invoiceId  String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  deletedAt  DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, kind])
  @@index([invoiceId])
}

// ─── Ekip Ataması ─────────────────────────────────────────────────────────────

model TeamAssignment {
  id       String @id @default(cuid())
  userId   String
  clientId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
}

// ─── Sosyal Medya Hesapları ───────────────────────────────────────────────────

model SocialAccount {
  id             String    @id @default(cuid())
  clientId       String
  platform       Platform
  accountId      String
  accountName    String
  accessTokenEnc String
  tokenExpiresAt DateTime?
  pageId         String?
  instagramId    String?
  // Bağlanan sayfanın profil fotoğrafı URL'si — OAuth callback sırasında
  // platform API'sinden çekip kaydediyoruz. UI'da hesap kartında
  // gösteriyoruz; null ise platform logosuna fallback.
  profileImageUrl String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]

  @@unique([clientId, platform, accountId])
  @@index([clientId])
}

// ─── Projeler / İçerikler ─────────────────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  clientId      String
  title         String
  description   String?
  status        ContentStatus @default(PLANNED)
  platforms     Platform[]
  postType      PostType      @default(IMAGE)
  shootDate     DateTime?
  shootLocation String?
  publishAt     DateTime?
  publishedAt   DateTime?
  brief         String?
  caption       String?
  hashtags      String[]
  // /yayin/hizli akışı arkada Project yaratır ama kullanıcı bunu üretim
  // sürecinin parçası olarak görmez. Bu flag ile /icerikler listesinden
  // gizliyoruz; /yayin sayfasında ScheduledPost'larıyla görünmeye devam eder.
  isQuickPublish Boolean      @default(false)
  // ─── Süreç Yönetimi alanları ────────────────────────────────────────
  // Amaç (çoktan seçmeli) — Süreç Yönetimi tablosundaki dropdown.
  purposes      Purpose[]
  // Üretim aşamaları — ContentStatus'dan bağımsız boolean checkbox'lar.
  // Bir proje "EDITING" durumunda olabilir ama briefi henüz onaylanmamış
  // olabilir → bu üçü ortogonal eksenler.
  briefDone     Boolean       @default(false)
  shootingDone  Boolean       @default(false)
  editingDone   Boolean       @default(false)
  // Reklam akışı — müşteri kartında "reklam çık" ibaresi + reklam çıkıldı
  // mı işareti. adRequired=true ve adPosted=false ise yayın sonrası 24h
  // içinde işaretlenmediğinde uyarı (yanıp söner) tetiklenir.
  adRequired    Boolean       @default(false)
  adPosted      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks          Task[]
  files          File[]
  approvals      Approval[]
  scheduledPosts ScheduledPost[]
  aiLogs         AiLog[]
  activityLogs   ActivityLog[]

  @@index([clientId, status])
  @@index([publishAt])
  // /icerikler listesi her zaman isQuickPublish=false + deletedAt=null filtreliyor.
  @@index([isQuickPublish, deletedAt])
}

// ─── Görevler ─────────────────────────────────────────────────────────────────

model Task {
  id           String    @id @default(cuid())
  projectId    String
  assignedToId String?
  title        String
  description  String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@index([projectId])
  @@index([assignedToId])
}

// ─── Dosyalar ─────────────────────────────────────────────────────────────────

model File {
  id         String    @id @default(cuid())
  projectId  String
  name       String
  mimeType   String
  sizeBytes  Int
  storageKey String    @unique
  publicUrl  String
  version    Int       @default(1)
  label      String?
  aiScore    Int?
  aiReport   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── Onaylar ──────────────────────────────────────────────────────────────────

model Approval {
  id             String             @id @default(cuid())
  projectId      String
  reviewerId     String?
  type           String
  status         ApprovalStatus     @default(PENDING)
  note           String?
  sentiment      SentimentCategory?
  sentimentScore Float?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer User?   @relation(fields: [reviewerId], references: [id])

  @@index([projectId])
}

// ─── Zamanlanmış Paylaşımlar ──────────────────────────────────────────────────

model ScheduledPost {
  id              String    @id @default(cuid())
  projectId       String
  socialAccountId String
  platform        Platform
  caption         String?
  hashtags        String[]
  mediaUrls       String[]
  scheduledAt     DateTime
  publishedAt     DateTime?
  status          String    @default("pending")
  retryCount      Int       @default(0)
  lastError       String?
  idempotencyKey  String    @unique @default(cuid())
  // Platform tarafındaki post ID (Meta media_id, LI urn:share:..., YT videoId,
  // TikTok publish_id). Yayın başarılıysa burada tutulur — tekrar dispatch
  // edildiğinde "zaten gönderildi" olarak atlanır + insights cron'u bunu kullanır.
  externalId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, status])
  // dispatchPublish project status sync count'u (projectId + status filter) ve
  // proje detay sayfasındaki yayın listesi bu indexten yararlanır.
  @@index([projectId, status])
}

// ─── Bildirimler ──────────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String?
  clientId   String?
  type       NotificationType
  title      String
  body       String
  entityType String?
  entityId   String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model NotificationPref {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  email  Boolean          @default(true)
  push   Boolean          @default(true)
  inApp  Boolean          @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ─── AI Log ───────────────────────────────────────────────────────────────────

model AiLog {
  id           String   @id @default(cuid())
  projectId    String?
  feature      String
  model        String
  inputHash    String?
  inputTokens  Int?
  outputTokens Int?
  durationMs   Int?
  cached       Boolean  @default(false)
  createdAt    DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([feature, createdAt])
}

// ─── Abonelikler (aylık retainer) ─────────────────────────────────────────────

model Subscription {
  id              String               @id @default(cuid())
  clientId        String
  name            String               // "Instagram Yönetimi - Aylık Retainer"
  description     String?
  amount          Decimal              @db.Decimal(12, 2) // KDV öncesi aylık tutar
  currency        Currency             @default(TRY)
  vatRate         Decimal              @db.Decimal(5, 2) @default(20.00)
  interval        SubscriptionInterval @default(MONTHLY)
  startDate       DateTime
  endDate         DateTime? // null = süresiz
  nextInvoiceDate DateTime // cron bu tarihi kullanarak fatura üretir
  status          SubscriptionStatus   @default(ACTIVE)
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([clientId, status])
  @@index([nextInvoiceDate, status])
}

// ─── Faturalar ────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  clientId       String
  subscriptionId String? // null = ad-hoc proje faturası
  invoiceNumber  String        @unique // "2026-0001"
  title          String
  description    String?
  // Para birimi & tutarlar (KDV hariç → KDV → toplam)
  currency       Currency      @default(TRY)
  amount         Decimal       @db.Decimal(12, 2) // net (KDV hariç)
  vatRate        Decimal       @db.Decimal(5, 2) @default(20.00)
  vatAmount      Decimal       @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2) // amount + vatAmount
  // Durum & tarihler
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  sentAt         DateTime?
  paidAt         DateTime?
  // Ödeme
  paymentMethod  String? // "havale", "eft", "nakit", "kart"
  paymentNote    String?
  // Müşteriye gösterilen not (ör. IBAN, açıklama)
  publicNote     String?
  // PDF önbelleği
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([clientId, status])
  @@index([dueDate, status])
  @@index([issueDate])
}

// ─── Aktivite Logu ────────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  projectId String?
  action    String
  details   Json?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
}
